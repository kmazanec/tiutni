# Copy to .env (gitignored) for local development. The conversational agent is
# LLM-driven and REQUIRES an OpenRouter key — the server will not start without it.
#
# Get a key at https://openrouter.ai/keys

OPENROUTER_API_KEY=sk-or-...

# Optional. The model the agent uses (any OpenRouter model id). Defaults to
# CORELLIA_MODEL_MID, then deepseek/deepseek-v4-pro. For the most reliable
# tool-calling + warmest tone, anthropic/claude-haiku-latest is a great choice.
# TIUTNI_MODEL=anthropic/claude-haiku-latest
# CORELLIA_MODEL_MID=deepseek/deepseek-v4-pro

# Optional base URL override.
# OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
